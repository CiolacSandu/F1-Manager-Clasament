<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="500"
        x:Class="F1ManagerAvalonia.Formulare.RegisterWindow"
        Title="Înregistrare - F1 Manager"
        Width="400" Height="500"
        CanResize="False"
        WindowStartupLocation="CenterScreen">
    <Panel Background="#1e1e2e">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" Width="300">
            <!-- Logo -->
            <Image Name="pictureBoxLogo" Width="180" Height="90" Stretch="Uniform" />

            <!-- Title -->
            <TextBlock Text="Creare Cont" FontSize="24" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center" />

             <!-- Username -->
             <TextBox Name="txtUsername" PlaceholderText="Username"
                      Background="#2d2d44" Foreground="White" BorderBrush="#444"
                      Height="40" FontSize="14" Padding="10,0" />

             <!-- Email -->
             <TextBox Name="txtEmail" PlaceholderText="Email"
                      Background="#2d2d44" Foreground="White" BorderBrush="#444"
                      Height="40" FontSize="14" Padding="10,0" />

             <!-- Password -->
             <TextBox Name="txtPassword" PlaceholderText="Parolă"
                      PasswordChar="●"
                      Background="#2d2d44" Foreground="White" BorderBrush="#444"
                      Height="40" FontSize="14" Padding="10,0" />

             <!-- Confirm Password -->
             <TextBox Name="txtConfirmPassword" PlaceholderText="Confirmă Parola"
                     PasswordChar="●"
                     Background="#2d2d44" Foreground="White" BorderBrush="#444"
                     Height="40" FontSize="14" Padding="10,0" />

            <!-- Register Button -->
            <Button Name="btnRegister" Content="Înregistrare"
                    Background="#e10600" Foreground="White"
                    FontSize="16" FontWeight="Bold" Height="45"
                    BorderThickness="0"
                    Cursor="Hand" />
        </StackPanel>
    </Panel>
</Window>